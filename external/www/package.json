{
  "name": "www",
  "private": true,
  "version": "0.0.0",
  "description": "",
  "type": "module",
  "imports": {
    "#design/*.css": "./src/shared/design/*/index.css",
    "#design/*.astro": "./src/shared/design/*/index.astro",
    "#design/*": "./src/shared/design/*/index.ts",
    "#shared/*.astro": "./src/shared/*/index.astro",
    "#shared/*": "./src/shared/*/index.ts"
  },
  "scripts": {
    "prelint": "astro sync",
    "lint": "pnpm run \"/^lint-.*/\"",
    "lint-astro": "astro check",
    "lint-typecheck": "tsc",
    "lint-eslint": "eslint .",
    "lint-prettier": "prettier --check .",
    "lint-knip": "knip",
    "test": "vitest",
    "dev": "astro dev",
    "clean": "rm -rf node_modules/.cache node_modules/.astro node_modules/.vite .astro coverage dist junit.xml tsconfig.tsbuildinfo",
    "build": "astro build"
  },
  "dependencies": {
    "@overlaysymphony/design": "workspace:*",
    "astro": "^7.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^7.0.0",
    "@overlaysymphony/tooling": "workspace:*",
    "@types/node": "^24.12.0",
    "eslint": "catalog:",
    "knip": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
