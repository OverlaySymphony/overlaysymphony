---
import Typography from "#design/elements/Typography.astro"

import { type Surface } from "./pane"

export * from "./pane"

export type Props = {
  label?: string
  surface?: Surface
  dotted?: boolean
  divided?: boolean
}

const {
  label,
  surface = "base",
  dotted = false,
  divided = true,
} = Astro.props

const hasHeader =
  Boolean(label) || Astro.slots.has("header") || Astro.slots.has("trailing")
const hasFooter = Astro.slots.has("footer")
---

<section class:list={["pane", surface, { divided }]}>
  {
    hasHeader && (
      <header class="head">
        <slot name="header">
          {label && (
            <Typography role="label" size="small" class="label">
              {label}
            </Typography>
          )}
        </slot>

        <slot name="trailing" />
      </header>
    )
  }

  <div class:list={["body", { dotted }]}>
    <slot />
  </div>

  {
    hasFooter && (
      <footer class="foot">
        <slot name="footer" />
      </footer>
    )
  }
</section>

<style>
  .pane {
    display: flex;
    flex-direction: column;
    min-width: 0;
    min-height: 0;
  }

  .base {
    background: var(--os-color-bg);
  }

  .raised {
    background: var(--os-color-bg-elev);
  }

  .divided {
    border-right: var(--os-hairline) solid var(--os-color-line);
  }

  .head {
    display: flex;
    flex: none;
    gap: var(--os-space-3);
    align-items: center;
    justify-content: space-between;
    height: var(--os-app-header-height);
    padding: 0 var(--os-space-4);
    border-bottom: var(--os-hairline) solid var(--os-color-line);
  }

  .label {
    color: var(--os-color-text-faint);
  }

  .body {
    flex: 1;
    min-height: 0;
    overflow: auto;
  }

  .dotted {
    background-image: radial-gradient(var(--os-color-dot) 1px, transparent 1px);
    background-size: 16px 16px;
  }

  .foot {
    flex: none;
    padding: var(--os-space-2);
    border-top: var(--os-hairline) solid var(--os-color-line);
  }
</style>
