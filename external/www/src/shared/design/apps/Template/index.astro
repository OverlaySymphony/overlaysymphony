---
import { type HTMLAttributes } from "astro/types"

import { parse, type Tone } from "./template"

export * from "./template"

export type Props = {
  value: string
  tone?: Tone
} & Omit<HTMLAttributes<"span">, "style">

const { value, tone = "trigger", class: className, ...props } = Astro.props
---

<span {...props} class:list={["template", tone, className]}>
  {
    parse(value).map((segment) =>
      segment.token ? (
        <span class="token">{segment.text}</span>
      ) : (
        <Fragment>{segment.text}</Fragment>
      ),
    )
  }
</span>

<style>
  .template {
    font-family: var(--os-font-code);
    font-size: var(--os-code-medium-size);
    line-height: var(--os-code-medium-leading);
    color: var(--os-color-text);
    overflow-wrap: anywhere;
  }

  .token {
    padding: 0 var(--os-space-1);
    color: var(--token-color);
    background: var(--token-wash);
    border-radius: var(--os-radius-sm);
  }

  .trigger {
    --token-color: var(--os-color-trigger);
    --token-wash: var(--os-color-trigger-wash);
  }

  .condition {
    --token-color: var(--os-color-condition);
    --token-wash: var(--os-color-condition-wash);
  }

  .action {
    --token-color: var(--os-color-action);
    --token-wash: var(--os-color-action-wash);
  }
</style>
