---
import Template from "#design/apps/Template.astro"

import { type StatusItem } from "./status-list"

export * from "./status-list"

export type Props = {
  items: StatusItem[]
  copyable?: boolean
}

const { items, copyable = false } = Astro.props
---

<ul class="list">
  {
    items.map((item) => {
      const Component = copyable ? "button" : "span"

      return (
        <li>
          <Component
            class="row"
            type={copyable ? "button" : undefined}
            data-copy={copyable ? item.key : undefined}
            title={copyable ? "Copy" : undefined}
          >
            <Template value={item.key} tone={item.tone} class="key" />
            {item.value && <span class="value">{item.value}</span>}
          </Component>
        </li>
      )
    })
  }
</ul>

<style>
  .list {
    display: flex;
    flex-direction: column;
    gap: var(--os-space-1);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .row {
    display: flex;
    gap: var(--os-space-3);
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--os-space-2);
    text-align: left;
    background: transparent;
    border: 0;
    border-radius: var(--os-radius-sm);
    transition: background var(--os-transition-fast);
  }

  button.row:hover {
    background: var(--os-color-bg-elev-2);
  }

  .key {
    min-width: 0;
  }

  .value {
    flex: none;
    font-family: var(--os-font-code);
    font-size: var(--os-code-small-size);
    color: var(--os-color-text-faint);
  }

  /* Set by the page's copy handler and cleared a moment later. */
  button.row[data-copied] .value {
    color: var(--os-color-teal);
  }

  button.row[data-copied] .value::after {
    content: " · copied";
  }
</style>
