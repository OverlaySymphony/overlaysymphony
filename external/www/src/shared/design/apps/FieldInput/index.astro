---
import { type HTMLAttributes } from "astro/types"

import Field from "#design/apps/Field.astro"

export type Props = {
  label: string
  help?: string
  prefix?: string
  suffix?: string
  mono?: boolean
} & Omit<HTMLAttributes<"input">, "style">

const {
  label,
  help,
  prefix,
  suffix,
  mono = false,
  class: className,
  ...props
} = Astro.props

const hasAction = Astro.slots.has("action")
---

<Field label={label} help={help}>
  <div class="control">
    {prefix && <span class="affix prefix">{prefix}</span>}

    <input {...props} class:list={["input", { mono }, className]} />

    {suffix && <span class="affix suffix">{suffix}</span>}

    {
      hasAction && (
        <div class="action">
          <slot name="action" />
        </div>
      )
    }
  </div>
</Field>

<style>
  .control {
    display: flex;
    align-items: stretch;
    overflow: hidden;
    background: var(--os-color-bg);
    border: var(--os-hairline) solid var(--os-color-line-strong);
    border-radius: var(--os-radius-sm);
    transition: border-color var(--os-transition-fast);
  }

  .control:focus-within {
    border-color: var(--os-color-teal);
  }

  .input {
    width: 100%;
    min-width: 0;
    padding: var(--os-space-2) var(--os-space-3);
    font-size: var(--os-control-small-size);
    background: transparent;
    border: 0;
    outline: none;
  }

  .mono {
    font-family: var(--os-font-code);
  }

  .affix {
    display: inline-flex;
    flex: none;
    align-items: center;
    padding: 0 var(--os-space-3);
    font-family: var(--os-font-code);
    font-size: var(--os-code-small-size);
    color: var(--os-color-text-faint);
  }

  .prefix {
    border-right: var(--os-hairline) solid var(--os-color-line-strong);
  }

  .suffix {
    border-left: var(--os-hairline) solid var(--os-color-line-strong);
  }

  .action {
    display: flex;
    flex: none;
    align-items: stretch;
  }
</style>
