---
import Container from "#design/elements/Container.astro"

import Logo from "#design/elements/Logo.astro"

const links = [
  {
    label: "Docs",
    href: "https://github.com/OverlaySymphony/overlaysymphony#readme",
  },
  {
    label: "GitHub",
    href: "https://github.com/OverlaySymphony/overlaysymphony",
  },
  {
    label: "Changelog",
    href: "https://github.com/OverlaySymphony/overlaysymphony/releases",
  },
]
---

<footer class="footer">
  <Container class="row">
    <div class="brand">
      <Logo size="small" markOnly />
      <span class="meta">Overlay Symphony &middot; MIT</span>
    </div>

    <nav class="links">
      {
        links.map(({ label, href }) => (
          <a class="link" href={href}>
            {label}
          </a>
        ))
      }
    </nav>
  </Container>
</footer>

<style>
  .footer {
    padding: var(--os-space-12) 0;
    border-top: var(--os-hairline) solid var(--os-color-line);
  }

  .row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--os-space-6);
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    display: flex;
    gap: var(--os-space-3);
    align-items: center;
  }

  .meta {
    font-family: var(--os-font-code);
    font-size: var(--os-label-large-size);
    letter-spacing: var(--os-label-medium-tracking);
    text-transform: uppercase;
    color: var(--os-color-text-faint);
  }

  .links {
    display: flex;
    gap: var(--os-space-6);
  }

  .link {
    font-size: var(--os-control-small-size);
    color: var(--os-color-text-muted);
    transition: color var(--os-transition-fast);
  }

  .link:hover {
    color: var(--os-color-text);
  }
</style>
