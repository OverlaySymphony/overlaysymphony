---
import Eyebrow from "#design/elements/Eyebrow.astro"
import Logo from "#design/elements/Logo.astro"

import Avatar from "./Avatar.astro"

export type Props = {
  path?: string[]
  status?: string
  initials?: string
}

const { path = [], status, initials } = Astro.props
---

<header class="topbar">
  <div class="brand">
    <Logo href="/" />
  </div>

  <nav class="path">
    {
      path.map((segment, index) => (
        <>
          {index > 0 && (
            <span class="separator" aria-hidden="true">
              /
            </span>
          )}
          <span class:list={{ current: index === path.length - 1 }}>
            {segment}
          </span>
        </>
      ))
    }
  </nav>

  <div class="actions">
    <slot name="actions" />

    {
      status && (
        <Eyebrow marker="accent" tone="muted" size="medium">
          {status}
        </Eyebrow>
      )
    }

    {initials && <Avatar initials={initials} />}
  </div>
</header>

<style>
  .topbar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--os-space-6);
    align-items: center;
    padding: 0 var(--os-space-4);
    border-bottom: var(--os-hairline) solid var(--os-color-line);
  }

  .path {
    display: flex;
    gap: var(--os-space-2);
    align-items: center;
    justify-content: center;
    min-width: 0;
    overflow: hidden;
    font-family: var(--os-font-code);
    font-size: var(--os-label-large-size);
    letter-spacing: var(--os-label-large-tracking);
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--os-color-text-muted);
  }

  .separator {
    color: var(--os-color-text-faint);
  }

  .current {
    overflow: hidden;
    text-overflow: ellipsis;
    text-transform: none;
    color: var(--os-color-text);
  }

  .actions {
    display: flex;
    gap: var(--os-space-5);
    align-items: center;
    justify-content: flex-end;
  }
</style>
