---
import Layout from "#design/layouts/RootLayout.astro"
import { type Breadcrumb, getStructure } from "#shared/breadcrumbs"

import TopBar from "./TopBar.astro"

export type Props = {
  /** The app's own location, deepest segment last — not the site's route breadcrumbs. */
  path?: string[]
  status?: string
  initials?: string
  children: unknown
}

const { path, status, initials } = Astro.props

const { title } = getStructure(Astro.locals.breadcrumbs as Breadcrumb[])
---

<Layout title={title} fullscreen>
  <div class="app">
    <TopBar path={path} status={status} initials={initials}>
      <slot name="actions" slot="actions" />
    </TopBar>

    <main class="body">
      <slot />
    </main>
  </div>
</Layout>

<style>
  .app {
    display: grid;
    grid-template-rows: var(--os-app-topbar-height) 1fr;
    height: 100vh;
  }

  .body {
    min-height: 0;
  }
</style>
