---
import FieldInput from "#design/apps/FieldInput.astro"
import FieldSelect from "#design/apps/FieldSelect.astro"
import ItemList from "#design/apps/ItemList.astro"
import NodeGraph from "#design/apps/NodeGraph.astro"
import Pane from "#design/apps/Pane.astro"
import StatusList from "#design/apps/StatusList.astro"
import Button from "#design/elements/Button.astro"
import Eyebrow from "#design/elements/Eyebrow.astro"
import Icon from "#design/elements/Icon.astro"
import Typography from "#design/elements/Typography.astro"
import { Breadcrumb } from "#shared/page"

import Layout from "./_Layout.astro"
---

<Breadcrumb href="/editor" label="Editor" />

<Layout
  path={["Alerts", "new-follower.automation"]}
  status="Saved · 2s ago"
  initials="CB"
>
  <Button slot="actions" variant="text" size="small" href="/">Open dock</Button>

  <div class="editor">
    <Pane label="Compositions">
      <Typography slot="trailing" role="label" size="small" class="count">
        3
      </Typography>

      <ItemList
        active="alerts"
        items={[
          { id: "alerts", name: "Alerts", badge: "4" },
          { id: "background", name: "Background", badge: "7" },
          { id: "commands", name: "Commands", badge: "12" },
        ]}
      />

      <Button slot="footer" variant="dashed" size="xsmall" block>
        + New composition
      </Button>
    </Pane>

    <Pane label="Automations">
      <Typography slot="trailing" role="label" size="small" class="count">
        4
      </Typography>

      <ItemList
        active="follow"
        items={[
          { id: "follow", name: "New follower", badge: "ON" },
          { id: "sub", name: "Subscription", badge: "ON" },
          { id: "bits", name: "Bits", badge: "ON" },
          { id: "shoutout", name: "!so command", badge: "OFF" },
        ]}
      />

      <Button slot="footer" variant="dashed" size="xsmall" block>
        + New automation
      </Button>
    </Pane>

    <Pane dotted>
      <div class="canvas-title" slot="header">
        <Typography role="label" size="medium">Alerts</Typography>
        <span class="canvas-arrow" aria-hidden="true">&rsaquo;</span>
        <Typography role="label" size="medium" class="canvas-current">
          New follower
        </Typography>
      </div>

      <div class="toolbar" slot="trailing">
        <Button variant="text" size="xsmall" square aria-label="Run once">
          <span class="glyph"><Icon name="play" /></span>
        </Button>
        <Button variant="text" size="xsmall" square aria-label="Duplicate">
          <span class="glyph"><Icon name="copy" /></span>
        </Button>
        <Button variant="text" size="xsmall" square aria-label="Delete">
          <span class="glyph"><Icon name="trash" /></span>
        </Button>
      </div>

      <NodeGraph
        selected="n1"
        sections={[
          {
            label: "Trigger",
            kind: "trigger",
            nodes: [
              {
                id: "n1",
                kind: "trigger",
                module: "Twitch",
                title: "Channel · Follow",
                meta: "twitch.eventsub",
              },
            ],
          },
          {
            label: "Conditions · all must pass",
            kind: "condition",
            insert: "Add condition",
            nodes: [
              {
                id: "n2",
                kind: "condition",
                module: "Viewer",
                title: "Has role",
                meta: "viewer.role ≥ subscriber",
              },
            ],
          },
          {
            label: "Actions · run in parallel",
            kind: "action",
            layout: "fork",
            forkLabel: "Fork",
            insert: "Add action",
            nodes: [
              {
                id: "n3",
                kind: "action",
                module: "Overlay",
                title: "Show alert",
                meta: 'overlay.fire("welcome")',
              },
              {
                id: "n4",
                kind: "action",
                module: "Audio",
                title: "Speak text",
                meta: "audio.tts(elevenlabs)",
              },
            ],
          },
        ]}
      />
    </Pane>

    <Pane surface="raised" divided={false}>
      <Eyebrow slot="header" marker="trigger" tone="muted" size="small">
        Trigger &middot; <span class="inspector-module">Twitch</span>
      </Eyebrow>

      <div class="inspector">
        <FieldSelect
          label="Module"
          value="twitch"
          options={[
            { value: "twitch", label: "Twitch" },
            { value: "obs", label: "OBS" },
            { value: "timer", label: "Timer" },
            { value: "webhook", label: "Webhook" },
          ]}
        />

        <FieldSelect
          label="Event"
          value="follow"
          help="Fires once per new follower. Twitch dedupes within 24h."
          options={[
            { value: "follow", label: "Channel · Follow" },
            { value: "subscribe", label: "Channel · Subscribe" },
            { value: "cheer", label: "Channel · Cheer" },
            { value: "raid", label: "Channel · Raid" },
            { value: "chat", label: "Chat · Message" },
          ]}
        />

        <FieldInput label="Channel" prefix="@" mono value="yourname" />

        <FieldInput label="Debounce" suffix="ms" mono value="500" />

        <div class="outputs">
          <div class="outputs-head">
            <Typography role="label" size="small" class="count">
              Outputs &middot; 4
            </Typography>
            <Typography role="code" size="small" class="count">
              {"{trigger.…}"}
            </Typography>
          </div>

          <StatusList
            copyable
            items={[
              { key: "{trigger.user.name}", value: "string" },
              { key: "{trigger.user.id}", value: "string" },
              { key: "{trigger.user.created}", value: "date" },
              { key: "{trigger.timestamp}", value: "date" },
            ]}
          />

          <Typography as="p" role="body" size="small" class="outputs-help">
            Use these tokens inside Conditions and Actions. Click to copy.
          </Typography>
        </div>

        <Button variant="text" size="xsmall" tone="danger">
          Delete trigger
        </Button>
      </div>
    </Pane>
  </div>
</Layout>

<style>
  .editor {
    display: grid;
    grid-template-columns: 12.5rem 12.5rem minmax(0, 1fr) 18.75rem;
    height: 100%;
    min-height: 0;
  }

  .count {
    color: var(--os-color-text-faint);
  }

  .canvas-title {
    display: flex;
    gap: var(--os-space-2);
    align-items: center;
    color: var(--os-color-text-muted);
  }

  .canvas-arrow {
    color: var(--os-color-text-faint);
  }

  .canvas-current {
    color: var(--os-color-text);
  }

  .toolbar {
    display: flex;
    gap: var(--os-space-1);
    align-items: center;
  }

  .glyph {
    display: block;
    width: var(--os-space-4);
    height: var(--os-space-4);
  }

  .inspector-module {
    color: var(--os-color-text);
  }

  .inspector {
    display: flex;
    flex-direction: column;
    gap: var(--os-space-6);
    padding: var(--os-space-5) var(--os-space-4) var(--os-space-10);
  }

  .outputs {
    display: flex;
    flex-direction: column;
    gap: var(--os-space-3);
    padding-top: var(--os-space-4);
    border-top: var(--os-hairline) dashed var(--os-color-line);
  }

  .outputs-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .outputs-help {
    color: var(--os-color-text-faint);
  }
</style>

<script>
  /** Moves `className` onto `target`, taking it off every peer. */
  function select(peers: Iterable<Element>, target: Element, className: string) {
    for (const peer of peers) peer.classList.remove(className)

    target.classList.add(className)
  }

  for (const item of document.querySelectorAll("[data-select]")) {
    const peers = item.closest("ul")?.querySelectorAll("[data-select]") ?? []

    item.addEventListener("click", () => select(peers, item, "active"))
  }

  const nodes = document.querySelectorAll("[data-node]")

  for (const node of nodes) {
    node.addEventListener("click", () => select(nodes, node, "selected"))
  }

  for (const button of document.querySelectorAll<HTMLElement>("[data-copy]")) {
    button.addEventListener("click", () => {
      void navigator.clipboard.writeText(button.dataset.copy ?? "")

      button.dataset.copied = "true"
      setTimeout(() => delete button.dataset.copied, 1200)
    })
  }
</script>
