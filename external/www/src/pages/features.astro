---
import Button from "#design/elements/Button.astro"
import Card from "#design/patterns/Card.astro"
import CardGrid from "#design/patterns/CardGrid.astro"
import Hero from "#design/patterns/Hero.astro"
import NodeGraph from "#design/patterns/NodeGraph.astro"
import Section from "#design/patterns/Section.astro"
import StatusList from "#design/patterns/StatusList.astro"
import Window from "#design/patterns/Window.astro"
import Breadcrumb from "#shared/breadcrumbs/Breadcrumb.astro"

import Layout from "./_Layout.astro"
---

<Breadcrumb href="/features" label="Features" />

<Layout>
  <Hero
    eyebrow="Features"
    headline="Everything runs where your *stream already runs*."
    sub="Symphony is built from small, independent modules that meet at a single idea: a **trigger** fires, **conditions** decide, **actions** happen — all inside the browser source you already have open in OBS."
  >
    <Button slot="actions" href="/modules" arrow>Browse the modules</Button>
    <Button slot="actions" href="/editor" variant="ghost">Open the editor</Button>
  </Hero>

  <Section
    index="01"
    eyebrow="The primitives"
    title="Four building blocks, endlessly recombined."
    lede="Learn them once. Every automation you'll ever write is some arrangement of these."
  >
    <CardGrid columns={4}>
      <Card icon="signal" title="Triggers" tag="eventsub · chat · obs">
        Twitch EventSub subscriptions, chat messages and commands, OBS scene and
        source events, timers. Anything that happens can start a chain.
      </Card>

      <Card icon="nodes" title="Conditions" tag="role · state · helix">
        Gate a chain on viewer role, follow age, command arguments, active scene,
        or the result of a Helix lookup. Branch instead of duplicating.
      </Card>

      <Card icon="scene" title="Actions" tag="overlay · obs · chat">
        Fire an overlay scene, drive OBS through its WebSocket, reply in chat, or
        hand off to another automation. Actions compose.
      </Card>

      <Card icon="grid" title="Helpers" tag="8 twitch helpers">
        Polls, predictions, hype trains, goals, charity campaigns, and
        channel-point redemptions arrive as ready-made state, not raw payloads.
      </Card>
    </CardGrid>
  </Section>

  <Section
    index="02"
    eyebrow="Node-based automations"
    title="Wire a chain, not a config file."
    lede="Chains read left to right. What fires it, what qualifies it, what it does."
  >
    <CardGrid columns={2} gap="spaced">
      <Card
        variant="raised"
        label="Example 01"
        title="Reward a returning subscriber"
      >
        An EventSub subscription arrives, the tier is checked, and an overlay
        scene plays — without a single round trip to anyone's server.

        <Window slot="media" title="routing / subscribe.automation" centered>
          <NodeGraph
            nodes={[
              {
                kind: "trigger",
                title: "Channel · Subscribe",
                meta: "twitch.eventsub",
              },
              {
                kind: "condition",
                title: "Tier 2 or higher",
                meta: "event.tier ≥ 2000",
              },
              {
                kind: "action",
                title: "Play overlay · Alert",
                meta: 'overlay.fire("sub")',
              },
            ]}
          />
        </Window>
      </Card>

      <Card variant="raised" label="Example 02" title="Give your mods a shortcut">
        A chat command is scoped to moderators, then drives OBS directly over its
        WebSocket. The same chain works in any scene.

        <Window slot="media" title="routing / shoutout.automation" centered>
          <NodeGraph
            nodes={[
              {
                kind: "trigger",
                title: "Chat · Command",
                meta: 'chat.command("!so")',
              },
              {
                kind: "condition",
                title: "Moderator only",
                meta: "user.role ≥ mod",
              },
              {
                kind: "action",
                title: "Switch OBS scene",
                meta: 'obs.setScene("shoutout")',
              },
            ]}
          />
        </Window>
      </Card>
    </CardGrid>
  </Section>

  <Section
    index="03"
    eyebrow="Twitch, already unpacked"
    title="The messy parts of the API, handled."
    lede="Helpers track the live state of the things viewers actually interact with, so your automations read it rather than reconstruct it."
  >
    <Window title="state / twitch.helpers">
      <StatusList
        framed={false}
        items={[
          { tone: "trigger", key: "hype-train", value: "level 3 · 62% to next" },
          { tone: "trigger", key: "poll", value: '"next game?" · 1,204 votes' },
          {
            tone: "condition",
            key: "prediction",
            value: "locked · 2 outcomes",
          },
          { tone: "action", key: "goal", value: "follower · 812 / 1000" },
          {
            tone: "muted",
            key: "charity",
            value: "— no active campaign",
            dim: true,
          },
        ]}
      />
    </Window>
  </Section>

  <Section
    index="04"
    eyebrow="Local by construction"
    title="If our site goes down, your stream doesn't notice."
    lede="Configuration is the only thing that touches us. The runtime never does."
  >
    <Window title="runtime / obs-browser-source">
      <StatusList
        framed={false}
        items={[
          { value: "obs browser source:" },
          {
            highlight: true,
            value: "file:///overlays/main.html#scene=starting-soon",
          },
          { tone: "trigger", key: "twitch.eventsub", value: "— connected" },
          { tone: "trigger", key: "obs.browser", value: "— attached" },
          { tone: "trigger", key: "overlays.scene", value: "— starting-soon" },
        ]}
      />
    </Window>
  </Section>
</Layout>
